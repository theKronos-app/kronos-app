{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "store:default",
    "fs:default",
    {
      "identifier": "fs:scope-app-recursive",
      "allow": [
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPCONFIG/**"
        },
        {
          "path": "$APPLOG/**"
        }
      ]
    },
    "fs:create-app-specific-dirs",
    "fs:allow-app-write-recursive",
    "fs:allow-app-read-recursive",
    "fs:allow-app-meta-recursive",
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPCONFIG/**"
        },
        {
          "path": "$APPLOG/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPCONFIG/**"
        },
        {
          "path": "$APPLOG/**"
        }
      ]
    }
  ]
}
